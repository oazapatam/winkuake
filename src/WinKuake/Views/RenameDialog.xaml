<Window x:Class="WinKuake.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renombrar pestaña"
        Width="320" Height="130"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ChromeBackground}"
        Foreground="{DynamicResource ChromeForeground}"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="14">
        <TextBlock Text="Nuevo nombre:" Margin="0,0,0,6" />
        <TextBox x:Name="TxtName"
                 Background="#252526"
                 Foreground="{DynamicResource ChromeForeground}"
                 BorderBrush="{DynamicResource ChromeBorder}"
                 Padding="6,4"
                 KeyDown="TxtName_KeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Style="{StaticResource ChromeButton}" Padding="14,6"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Aceptar"  Style="{StaticResource ChromeButton}" Padding="14,6"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    Click="Accept_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
