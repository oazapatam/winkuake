<Window x:Class="WinKuake.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar WinKuake"
        Width="540" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ChromeBackground}"
        Foreground="{DynamicResource ChromeForeground}"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#252526" />
            <Setter Property="Foreground"  Value="{DynamicResource ChromeForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorder}" />
            <Setter Property="Padding"     Value="4,2" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#252526" />
            <Setter Property="Foreground"  Value="{DynamicResource ChromeForeground}" />
            <Setter Property="Padding"     Value="14,6" />
            <Setter Property="FontSize"    Value="13" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource ChromeBorder}">

            <!-- =================== VENTANA =================== -->
            <TabItem Header="Ventana">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Tamaño y posición" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Alto (% pantalla)"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeight"
                                    Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" />
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="TxtHeight"
                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                     ToolTip="Porcentaje (1–100). 100% cubre la pantalla entera incluyendo la barra de tareas." />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ancho (% pantalla)"
                                       VerticalAlignment="Center" Margin="0,8,0,0" />
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SldWidth"
                                    Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" Margin="0,8,0,0" />
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="TxtWidth"
                                     VerticalAlignment="Center" Margin="6,8,0,0"
                                     ToolTip="Porcentaje (1–100)." />
                        </Grid>

                        <TextBlock Text="Animación slide (ms)" FontWeight="SemiBold" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtAnim" Width="80" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== COMPORTAMIENTO =================== -->
            <TabItem Header="Comportamiento">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Hotkey global" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="ChkCtrl"  Content="Ctrl"  Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkAlt"   Content="Alt"   Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkShift" Content="Shift" Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkWin"   Content="Win"   Margin="0,0,12,0" />
                            <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="CmbKey" Width="120" />
                        </StackPanel>

                        <TextBlock Text="Cuando pierde el foco" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <CheckBox x:Name="ChkAutoHide"  Content="Ocultar automáticamente"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="Al iniciar sesión" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <CheckBox x:Name="ChkStartup"   Content="Lanzar WinKuake con Windows"
                                  Margin="0,0,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== TERMINAL =================== -->
            <TabItem Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Tema" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="CmbTheme" Width="220" HorizontalAlignment="Left"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="Tamaño de fuente (pt)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SldFontSize"
                                    Minimum="8" Maximum="32" TickFrequency="1"
                                    IsSnapToTickEnabled="True" />
                            <TextBox Grid.Column="1" x:Name="TxtFontSize"
                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                     ToolTip="Tamaño de fuente del terminal en puntos (8–32)." />
                        </Grid>

                        <TextBlock Text="Scrollback (historial)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Cuántas líneas guardar para hacer scroll hacia atrás. Ilimitado por defecto."
                                   FontSize="11" Foreground="#9A9A9A" Margin="0,0,0,6" />
                        <ComboBox x:Name="CmbScrollback" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem Tag="-1"     Content="Ilimitado (recomendado)" />
                            <ComboBoxItem Tag="1000"   Content="1 000 líneas" />
                            <ComboBoxItem Tag="10000"  Content="10 000 líneas" />
                            <ComboBoxItem Tag="50000"  Content="50 000 líneas" />
                            <ComboBoxItem Tag="100000" Content="100 000 líneas" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== APARIENCIA =================== -->
            <TabItem Header="Apariencia">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Opacidad" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SldOpacity"
                                    Minimum="0.5" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" />
                            <TextBox  Grid.Column="1" x:Name="TxtOpacity"
                                      VerticalAlignment="Center" Margin="6,0,0,0"
                                      ToolTip="Porcentaje (50–100)." />
                        </Grid>

                        <TextBlock Text="Colores del chrome (skin)" FontWeight="SemiBold" Margin="0,4,0,4" />
                        <TextBlock Text="Hex #RRGGBB. Las claves se aplican en caliente al guardar."
                                   FontSize="11" Foreground="#9A9A9A" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fondo del chrome"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtChromeBg"
                                      Margin="0,4" />
                            <Border   Grid.Row="0" Grid.Column="2" x:Name="SwChromeBg"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Color de texto"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtChromeFg"
                                      Margin="0,4" />
                            <Border   Grid.Row="1" Grid.Column="2" x:Name="SwChromeFg"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Borde / separador"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtChromeBorder"
                                      Margin="0,4" />
                            <Border   Grid.Row="2" Grid.Column="2" x:Name="SwChromeBorder"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Acento (pestaña activa)"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TxtAccent"
                                      Margin="0,4" />
                            <Border   Grid.Row="3" Grid.Column="2" x:Name="SwAccent"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />
                        </Grid>

                        <Button Content="Restaurar valores por defecto"
                                Style="{StaticResource ChromeButton}"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0" Padding="12,6"
                                Click="ResetSkin_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Style="{StaticResource ChromeButton}" Padding="14,6"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Guardar"  Style="{StaticResource ChromeButton}" Padding="14,6"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
