<Window x:Class="WinKuake.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinKuake — Settings"
        Width="540" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ChromeBackground}"
        Foreground="{DynamicResource ChromeForeground}"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#252526" />
            <Setter Property="Foreground"  Value="{DynamicResource ChromeForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorder}" />
            <Setter Property="Padding"     Value="4,2" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#252526" />
            <Setter Property="Foreground"  Value="{DynamicResource ChromeForeground}" />
            <Setter Property="Padding"     Value="14,6" />
            <Setter Property="FontSize"    Value="13" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource ChromeBorder}">

            <!-- =================== PERFILES =================== -->
            <TabItem Header="Profiles">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="Auto-detected terminals plus any you add by hand. Mark the default with the radio button. Hide entries you don't use without deleting them." />

                    <DataGrid Grid.Row="1"
                              x:Name="ProfilesGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              Background="#252526"
                              Foreground="{DynamicResource ChromeForeground}"
                              RowBackground="#252526"
                              AlternatingRowBackground="#1f1f1f"
                              BorderBrush="{DynamicResource ChromeBorder}"
                              KeyDown="ProfilesGrid_KeyDown">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Default" Width="60" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="DefaultProfileGroup"
                                                     HorizontalAlignment="Center"
                                                     IsChecked="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}"
                                                     Click="DefaultRadio_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Visible" Binding="{Binding Visible, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                            <DataGridTextColumn     Header="Icon"    Binding="{Binding IconGlyph}"   Width="60" />
                            <DataGridTextColumn     Header="Name"    Binding="{Binding Name}"        Width="160" />
                            <DataGridTextColumn     Header="Command line" Binding="{Binding CommandLine}" Width="*" />
                            <DataGridTextColumn     Header="Cwd"     Binding="{Binding StartingDirectory}" Width="160" />
                            <DataGridTextColumn     Header="Source"  Binding="{Binding Source}"      Width="80" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Detect terminals" Style="{StaticResource ChromeButton}"
                                Padding="10,4" Margin="0,0,8,0" Click="DetectTerminals_Click" />
                        <Button Content="Add custom" Style="{StaticResource ChromeButton}"
                                Padding="10,4" Margin="0,0,8,0" Click="AddManualProfile_Click" />
                        <Button Content="Reset" Style="{StaticResource ChromeButton}"
                                Padding="10,4" Margin="0,0,8,0" Click="ResetProfiles_Click" />
                        <TextBlock Text="Tip: Delete removes the selected row."
                                   FontSize="11" Foreground="#9A9A9A" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- =================== VENTANA =================== -->
            <TabItem Header="Window">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Size and position" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Height (% of screen)"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeight"
                                    Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" />
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="TxtHeight"
                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                     ToolTip="Percentage (1–100). 100% covers the whole screen, taskbar included." />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Width (% of screen)"
                                       VerticalAlignment="Center" Margin="0,8,0,0" />
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SldWidth"
                                    Minimum="0.1" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" Margin="0,8,0,0" />
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="TxtWidth"
                                     VerticalAlignment="Center" Margin="6,8,0,0"
                                     ToolTip="Percentage (1–100)." />
                        </Grid>

                        <TextBlock Text="Slide animation (ms)" FontWeight="SemiBold" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtAnim" Width="80" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== COMPORTAMIENTO =================== -->
            <TabItem Header="Behavior">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Global hotkey" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="ChkCtrl"  Content="Ctrl"  Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkAlt"   Content="Alt"   Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkShift" Content="Shift" Margin="0,0,8,0" />
                            <CheckBox x:Name="ChkWin"   Content="Win"   Margin="0,0,12,0" />
                            <TextBlock Text="+" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="CmbKey" Width="120" />
                        </StackPanel>

                        <TextBlock Text="On focus loss" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <CheckBox x:Name="ChkAutoHide"  Content="Auto-hide"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="On Windows sign-in" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <CheckBox x:Name="ChkStartup"   Content="Launch WinKuake at startup"
                                  Margin="0,0,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== TERMINAL =================== -->
            <TabItem Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="CmbTheme" Width="220" HorizontalAlignment="Left"
                                  Margin="0,0,0,12" />

                        <!-- Editor de paleta custom: solo visible cuando el tema seleccionado es "Custom". -->
                        <Border x:Name="CustomThemePanel" Visibility="Collapsed"
                                BorderBrush="{DynamicResource ChromeBorder}" BorderThickness="1"
                                Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Customize this theme" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock Text="Hex #RRGGBB for every terminal color."
                                           FontSize="11" Foreground="#9A9A9A" Margin="0,0,0,8" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"  Grid.Column="0" Text="Name"            VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="0"  Grid.Column="1" x:Name="TxtCtName"     Margin="0,2" />

                                    <TextBlock Grid.Row="1"  Grid.Column="0" Text="Background"      VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="1"  Grid.Column="1" x:Name="TxtCtBg"       Margin="0,2" />
                                    <Border   Grid.Row="1"  Grid.Column="2" x:Name="SwCtBg"       Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="2"  Grid.Column="0" Text="Foreground"      VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="2"  Grid.Column="1" x:Name="TxtCtFg"       Margin="0,2" />
                                    <Border   Grid.Row="2"  Grid.Column="2" x:Name="SwCtFg"       Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="3"  Grid.Column="0" Text="Cursor"          VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="3"  Grid.Column="1" x:Name="TxtCtCursor"   Margin="0,2" />
                                    <Border   Grid.Row="3"  Grid.Column="2" x:Name="SwCtCursor"   Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="4"  Grid.Column="0" Text="Black"           VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="4"  Grid.Column="1" x:Name="TxtCtBlack"    Margin="0,2" />
                                    <Border   Grid.Row="4"  Grid.Column="2" x:Name="SwCtBlack"    Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="5"  Grid.Column="0" Text="Red"             VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="5"  Grid.Column="1" x:Name="TxtCtRed"      Margin="0,2" />
                                    <Border   Grid.Row="5"  Grid.Column="2" x:Name="SwCtRed"      Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="6"  Grid.Column="0" Text="Green"           VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="6"  Grid.Column="1" x:Name="TxtCtGreen"    Margin="0,2" />
                                    <Border   Grid.Row="6"  Grid.Column="2" x:Name="SwCtGreen"    Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="7"  Grid.Column="0" Text="Yellow"          VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="7"  Grid.Column="1" x:Name="TxtCtYellow"   Margin="0,2" />
                                    <Border   Grid.Row="7"  Grid.Column="2" x:Name="SwCtYellow"   Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="8"  Grid.Column="0" Text="Blue"            VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="8"  Grid.Column="1" x:Name="TxtCtBlue"     Margin="0,2" />
                                    <Border   Grid.Row="8"  Grid.Column="2" x:Name="SwCtBlue"     Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="9"  Grid.Column="0" Text="Magenta"         VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="9"  Grid.Column="1" x:Name="TxtCtMagenta"  Margin="0,2" />
                                    <Border   Grid.Row="9"  Grid.Column="2" x:Name="SwCtMagenta"  Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Cyan"            VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="10" Grid.Column="1" x:Name="TxtCtCyan"     Margin="0,2" />
                                    <Border   Grid.Row="10" Grid.Column="2" x:Name="SwCtCyan"     Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="White"           VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="11" Grid.Column="1" x:Name="TxtCtWhite"    Margin="0,2" />
                                    <Border   Grid.Row="11" Grid.Column="2" x:Name="SwCtWhite"    Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Bright Black"    VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="12" Grid.Column="1" x:Name="TxtCtBBlack"   Margin="0,2" />
                                    <Border   Grid.Row="12" Grid.Column="2" x:Name="SwCtBBlack"   Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Bright Red"      VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="13" Grid.Column="1" x:Name="TxtCtBRed"     Margin="0,2" />
                                    <Border   Grid.Row="13" Grid.Column="2" x:Name="SwCtBRed"     Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="14" Grid.Column="0" Text="Bright Green"    VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="14" Grid.Column="1" x:Name="TxtCtBGreen"   Margin="0,2" />
                                    <Border   Grid.Row="14" Grid.Column="2" x:Name="SwCtBGreen"   Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="15" Grid.Column="0" Text="Bright Yellow"   VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="15" Grid.Column="1" x:Name="TxtCtBYellow"  Margin="0,2" />
                                    <Border   Grid.Row="15" Grid.Column="2" x:Name="SwCtBYellow"  Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="16" Grid.Column="0" Text="Bright Blue"     VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="16" Grid.Column="1" x:Name="TxtCtBBlue"    Margin="0,2" />
                                    <Border   Grid.Row="16" Grid.Column="2" x:Name="SwCtBBlue"    Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="17" Grid.Column="0" Text="Bright Magenta"  VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="17" Grid.Column="1" x:Name="TxtCtBMagenta" Margin="0,2" />
                                    <Border   Grid.Row="17" Grid.Column="2" x:Name="SwCtBMagenta" Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />

                                    <TextBlock Grid.Row="18" Grid.Column="0" Text="Bright Cyan"     VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Row="18" Grid.Column="1" x:Name="TxtCtBCyan"    Margin="0,2" />
                                    <Border   Grid.Row="18" Grid.Column="2" x:Name="SwCtBCyan"    Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bright White"    VerticalAlignment="Center" Margin="0,2" />
                                    <TextBox  Grid.Column="1" x:Name="TxtCtBWhite"   Margin="0,2" />
                                    <Border   Grid.Column="2" x:Name="SwCtBWhite"   Margin="6,2,0,2" BorderThickness="1" BorderBrush="{DynamicResource ChromeBorder}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Font size (pt)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SldFontSize"
                                    Minimum="8" Maximum="32" TickFrequency="1"
                                    IsSnapToTickEnabled="True" />
                            <TextBox Grid.Column="1" x:Name="TxtFontSize"
                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                     ToolTip="Terminal font size in points (8–32)." />
                        </Grid>

                        <TextBlock Text="Scrollback (history)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Lines kept for scrolling back. Unlimited by default."
                                   FontSize="11" Foreground="#9A9A9A" Margin="0,0,0,6" />
                        <ComboBox x:Name="CmbScrollback" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem Tag="-1"     Content="Unlimited (recommended)" />
                            <ComboBoxItem Tag="1000"   Content="1,000 lines" />
                            <ComboBoxItem Tag="10000"  Content="10,000 lines" />
                            <ComboBoxItem Tag="50000"  Content="50,000 lines" />
                            <ComboBoxItem Tag="100000" Content="100,000 lines" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =================== ATAJOS =================== -->
            <TabItem Header="Shortcuts">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,8"
                               Text="Custom shortcuts for WinKuake actions. Format: 'Ctrl+Shift+T', 'Alt+F4', etc." />

                    <DataGrid Grid.Row="1"
                              x:Name="KeybindingsGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              Background="#252526"
                              Foreground="{DynamicResource ChromeForeground}"
                              RowBackground="#252526"
                              AlternatingRowBackground="#1f1f1f"
                              BorderBrush="{DynamicResource ChromeBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Action" Binding="{Binding DisplayName}" Width="260" IsReadOnly="True" />
                            <DataGridTextColumn Header="Shortcut" Binding="{Binding Gesture}"   Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="11" Foreground="#9A9A9A"
                               Text="Changes will take effect in a future version." />
                </Grid>
            </TabItem>

            <!-- =================== SNIPPETS =================== -->
            <TabItem Header="Snippets">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,8"
                               Text="Custom snippets shown in the palette (Ctrl+Shift+P) on top of the defaults. Supports {cwd}, {home}, {user}, {date} variables." />

                    <DataGrid Grid.Row="1"
                              x:Name="SnippetsGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              CanUserResizeRows="False"
                              Background="#252526"
                              Foreground="{DynamicResource ChromeForeground}"
                              RowBackground="#252526"
                              AlternatingRowBackground="#1f1f1f"
                              BorderBrush="{DynamicResource ChromeBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="200" />
                            <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Tip: {cwd} expands to the shell's current directory when injecting."
                                   FontSize="11" Foreground="#9A9A9A" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- =================== APARIENCIA =================== -->
            <TabItem Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Text="Opacity" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SldOpacity"
                                    Minimum="0.5" Maximum="1.0" TickFrequency="0.01"
                                    SmallChange="0.01" LargeChange="0.05" />
                            <TextBox  Grid.Column="1" x:Name="TxtOpacity"
                                      VerticalAlignment="Center" Margin="6,0,0,0"
                                      ToolTip="Percentage (50–100)." />
                        </Grid>

                        <TextBlock Text="Chrome colors (skin)" FontWeight="SemiBold" Margin="0,4,0,4" />
                        <TextBlock Text="Hex #RRGGBB. Applied live on save."
                                   FontSize="11" Foreground="#9A9A9A" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Chrome background"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TxtChromeBg"
                                      Margin="0,4" />
                            <Border   Grid.Row="0" Grid.Column="2" x:Name="SwChromeBg"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Text color"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TxtChromeFg"
                                      Margin="0,4" />
                            <Border   Grid.Row="1" Grid.Column="2" x:Name="SwChromeFg"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Border / divider"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtChromeBorder"
                                      Margin="0,4" />
                            <Border   Grid.Row="2" Grid.Column="2" x:Name="SwChromeBorder"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Accent (active tab)"
                                       VerticalAlignment="Center" Margin="0,4" />
                            <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TxtAccent"
                                      Margin="0,4" />
                            <Border   Grid.Row="3" Grid.Column="2" x:Name="SwAccent"
                                      Margin="6,4,0,4" BorderThickness="1"
                                      BorderBrush="{DynamicResource ChromeBorder}" />
                        </Grid>

                        <Button Content="Reset to defaults"
                                Style="{StaticResource ChromeButton}"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0" Padding="12,6"
                                Click="ResetSkin_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"  Style="{StaticResource ChromeButton}" Padding="14,6"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Save"    Style="{StaticResource ChromeButton}" Padding="14,6"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
