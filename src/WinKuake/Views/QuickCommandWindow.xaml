<Window x:Class="WinKuake.Views.QuickCommandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paleta de comandos"
        Width="560" Height="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="{DynamicResource ChromeForeground}">
    <Border Background="{DynamicResource ChromeBackground}"
            BorderBrush="{DynamicResource ChromeBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Background="#252526"
                     Foreground="{DynamicResource ChromeForeground}"
                     BorderBrush="{DynamicResource ChromeBorder}"
                     FontSize="14"
                     Padding="8,6"
                     Margin="0,0,0,10" />

            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Background="Transparent"
                     Foreground="{DynamicResource ChromeForeground}"
                     BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2a" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Name}" FontSize="13" />
                            <TextBlock Text="{Binding Command}" FontSize="11" Opacity="0.65" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2"
                       Text="Enter inyecta · Shift+Enter inyecta+ejecuta · Esc cierra"
                       FontSize="11" Opacity="0.5" Margin="0,10,0,0" />
        </Grid>
    </Border>
</Window>
