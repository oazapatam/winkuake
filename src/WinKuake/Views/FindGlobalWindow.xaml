<Window x:Class="WinKuake.Views.FindGlobalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:WinKuake.Views"
        Title="Búsqueda global"
        Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="{DynamicResource ChromeForeground}">
    <Border Background="{DynamicResource ChromeBackground}"
            BorderBrush="{DynamicResource ChromeBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Background="#252526"
                     Foreground="{DynamicResource ChromeForeground}"
                     BorderBrush="{DynamicResource ChromeBorder}"
                     FontSize="14"
                     Padding="8,6" />

            <TextBlock x:Name="StatusLine"
                       Grid.Row="1"
                       FontSize="11" Opacity="0.5"
                       Margin="2,6,0,6"
                       Text="Buscando en todos los terminales abiertos." />

            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     Background="Transparent"
                     Foreground="{DynamicResource ChromeForeground}"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2a" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Header}"
                                       FontSize="11" Opacity="0.7" />
                            <TextBlock x:Name="PreviewBlock"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       v:FindResultPreview.Item="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="3"
                       Text="Enter abre · Doble-click abre · Esc cierra"
                       FontSize="11" Opacity="0.5" Margin="0,10,0,0" />
        </Grid>
    </Border>
</Window>
