<Window x:Class="WinKuake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinKuake"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="Transparent"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource ChromeBackground}"
            BorderBrush="{DynamicResource ChromeBorder}"
            BorderThickness="0,0,0,1"
            x:Name="RootBorder">

        <Grid>
            <!-- Layout estilo Yakuake:
                 fila 0 = terminal (todo el espacio)
                 fila 1 = tab bar           (~30 px)
                 fila 2 = status / control  (~28 px)  -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"  />
                <RowDefinition Height="30" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!-- Contenedor de las TerminalControls (una por sesión). Solo
                 la activa está visible; las demás permanecen en memoria
                 con Visibility=Collapsed para preservar su buffer. -->
            <Grid Grid.Row="0" Background="#0A0A0A" x:Name="TerminalContainer" />

            <!-- Tab bar estilo Windows Terminal (posicionada abajo, estilo Yakuake) -->
            <Grid Grid.Row="1" Background="{DynamicResource ChromeBackground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Lista de pestañas: ícono + nombre + ✕ por tab -->
                <ItemsControl Grid.Column="0" x:Name="TabsItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    Padding="10,4,6,4"
                                    Margin="0,2,1,0"
                                    CornerRadius="4,4,0,0"
                                    Tag="{Binding Index}"
                                    AllowDrop="True"
                                    MouseLeftButtonDown="Tab_MouseDown"
                                    MouseRightButtonDown="Tab_RightDown"
                                    MouseMove="Tab_MouseMove"
                                    DragOver="Tab_DragOver"
                                    Drop="Tab_Drop">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{DynamicResource ChromeForeground}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="180" />
                                    <Button Content="✕"
                                            Style="{StaticResource ChromeButton}"
                                            Foreground="#A0A0A0"
                                            FontSize="10"
                                            Padding="5,0"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Tag="{Binding Index}"
                                            ToolTip="Cerrar esta pestaña"
                                            Click="CloseSpecificTab_Click" />
                                </StackPanel>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#22FFFFFF" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- + : nueva tab con perfil del tab activo. v : abre dropdown de perfiles. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="NewTabButton"
                            Content="＋"
                            Style="{StaticResource ChromeButton}"
                            FontSize="14"
                            Padding="10,2"
                            ToolTip="Nueva pestaña con el perfil activo (Ctrl+Shift+T)"
                            Click="NewTabButton_Click" />
                    <Button x:Name="ProfilePickerButton"
                            Content="⌄"
                            Style="{StaticResource ChromeButton}"
                            FontSize="14"
                            Padding="6,2,8,2"
                            ToolTip="Elegir perfil para nueva pestaña"
                            Click="ProfilePickerButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ProfileMenu" />
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Status bar (icono + título a la izquierda; lock + menú + salir a la derecha) -->
            <Grid Grid.Row="2" Background="{DynamicResource ChromeBackground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="▣" FontSize="12"
                               Foreground="{DynamicResource ChromeForeground}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="StatusTitle"
                               Text="WinKuake — drop-down terminal"
                               Foreground="{DynamicResource ChromeForeground}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Centro: drag region -->
                <Border Grid.Column="1" Background="Transparent"
                        MouseLeftButtonDown="ChromeDrag_MouseLeftButtonDown" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="LockButton"
                            Content="○"
                            Style="{StaticResource ChromeButton}"
                            FontSize="12"
                            Padding="8,2"
                            ToolTip="Lock: cuando está activo, la ventana no se auto-oculta al perder foco"
                            Click="LockButton_Click" />
                    <Button Content="≡"
                            Style="{StaticResource ChromeButton}"
                            FontSize="14"
                            Padding="8,2"
                            ToolTip="Menú (configuración, ayuda)"
                            Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="HamburgerMenu">
                                <MenuItem Header="Configurar Yakuake…  (Ctrl+Shift+,)" Click="OpenSettings_Click" />
                                <Separator />
                                <MenuItem Header="Nueva pestaña       (Ctrl+Shift+T)" Click="MenuNewTab_Click" />
                                <MenuItem Header="Dividir vertical    (Alt+Shift++)"  Click="SplitVertical_Click" />
                                <MenuItem Header="Dividir horizontal  (Alt+Shift+−)"  Click="SplitHorizontal_Click" />
                                <Separator />
                                <MenuItem Header="Ocultar (Win+F12)"  Click="HideButton_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="✕"
                            Style="{StaticResource ChromeButton}"
                            Foreground="#D04848"
                            FontSize="13"
                            Padding="8,2"
                            ToolTip="Salir de WinKuake"
                            Click="ExitButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
